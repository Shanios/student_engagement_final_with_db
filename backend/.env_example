# ===============================
# Camera / Device Configuration
# ===============================
CAMERA_DEVICE_KEY=your-camera-device-key-generate-with-secrets-module

# ===============================
# Email (SMTP) Configuration - Optional
# ===============================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_email_app_password

# ===============================
# Groq LLM Configuration
# ===============================
GROQ_API_KEY=gsk_your-groq-api-key-here

# ===============================
# Backend Configuration
# ===============================
BACKEND_BASE=http://127.0.0.1:8000
AUTO_CREATE_TABLES=true

# ===============================
# Database (PostgreSQL via Supabase)
# ===============================
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ===============================
# Supabase Storage Configuration
# ===============================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key...

# ===============================
# RAG Embeddings (Downloads from Supabase Storage)
# ===============================
RAG_EMBEDDINGS_URL=https://your-project.supabase.co/storage/v1/object/public/rag-embeddings/embeddings.npy
RAG_CHUNKS_URL=https://your-project.supabase.co/storage/v1/object/public/rag-embeddings/text_chunks.npy

# ===============================
# Security & Authentication
# ===============================
JWT_SECRET=your-jwt-secret-generate-with-secrets-module
SECRET_KEY=your-secret-key-generate-with-secrets-module

# ===============================
# Video Conferencing (Zego Cloud)
# ===============================
ZEGOCLOUD_APP_ID=your-zego-app-id
ZEGOCLOUD_SERVER_SECRET=your-zego-server-secret

# ===============================
# Environment & ML Settings
# ===============================
ENV=development
DISABLE_LOCAL_ML=false

# ===============================
# HOW TO GENERATE SECURE VALUES
# ===============================
# For SECRET_KEY and JWT_SECRET:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# For CAMERA_DEVICE_KEY:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# For Database URL:
# Get from Supabase → Settings → Database → Connection string
#
# For Supabase credentials:
# Get from Supabase → Settings → API
#
# For Groq API Key:
# Get from https://console.groq.com/keys
#
# For Zego Cloud:
# Get from https://console.zegocloud.com/